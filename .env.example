# Credenciais do Firebase (Console > Configurações do projeto > Seus apps > SDK).
# Copie este arquivo para ".env" e preencha com os valores do SEU projeto.
# Atenção: estas chaves são públicas por natureza (apps web). A segurança dos
# dados é garantida pelas regras do Firestore (firestore.rules).

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
